   296	static constexpr __host__ __device__ int calc_nwarps(ggml_type type, int ncols_dst, mmvq_parameter_table_id table_id) {
   297	    if (table_id == MMVQ_PARAMETERS_GENERIC) {
   298	        switch (ncols_dst) {
   299	            case 1:
   300	            case 2:
   301	            case 3:
   302	            case 4:
   303	                return 4;
   304	            case 5:
   305	            case 6:
   306	            case 7:
   307	            case 8:
   308	                return 2;
   309	            default:
   310	                return 1;
   311	        }
   312	    } else if (table_id == MMVQ_PARAMETERS_GCN) {
   313	        switch (ncols_dst) {
   314	            case 1:
   315	            case 2:
   316	            case 3:
   317	            case 4:
   318	                return 2;
   319	            case 5:
   320	            case 6:
   321	            case 7:
   322	            case 8:
   323	            default:
   324	                return 1;
   325	        }
   326	    }
   327	    if (table_id == MMVQ_PARAMETERS_RDNA4) {
   328	        // nwarps=8 benefits types with simple vec_dot on RDNA4 (ncols_dst=1).
   329	        // Types with complex vec_dot (Q3_K, IQ2_*, IQ3_*) regress due to register
   330	        // pressure and lookup table contention at higher thread counts.
   331	        if (ncols_dst == 1) {
   332	            switch (type) {
   333	                case GGML_TYPE_Q4_0:
   334	                case GGML_TYPE_Q4_1:
   335	                case GGML_TYPE_Q5_0:
   336	                case GGML_TYPE_Q5_1:
   337	                case GGML_TYPE_Q8_0:
   338	                case GGML_TYPE_Q2_K:
   339	                case GGML_TYPE_Q4_K:
   340	                case GGML_TYPE_Q5_K:
   341	                case GGML_TYPE_Q6_K:
   342	                case GGML_TYPE_IQ4_NL:
   343	                case GGML_TYPE_IQ4_XS:
   344	                    return 8;
   345	                default:
   346	                    return 1;
   347	            }
   348	        }
   349	        return 1;
   350	    }
   351	    if (table_id == MMVQ_PARAMETERS_RDNA3_0) {
   352	        // RDNA3 (W7900): stricter whitelist than RDNA4.
   353	        // Q2_K / Q5_K / IQ4_XS regress in full quant sweeps.
   354	        if (ncols_dst == 1) {
   355	            switch (type) {
   356	                case GGML_TYPE_Q4_0:
   357	                case GGML_TYPE_Q4_1:
   358	                case GGML_TYPE_Q5_0:
   359	                case GGML_TYPE_Q5_1:
   360	                case GGML_TYPE_Q8_0:
   361	                case GGML_TYPE_Q4_K:
   362	                case GGML_TYPE_Q6_K:
   363	                case GGML_TYPE_IQ4_NL:
   364	                    return 8;
   365	                default:
   366	                    return 1;
   367	            }
   368	        }
   369	        return 1;
   370	    }
   371	    return 1;
   372	}
   373	
   374	static constexpr __host__ __device__ int calc_rows_per_block(int ncols_dst, int table_id, bool small_k = false, int nwarps = 1) {
   375	    if (table_id == MMVQ_PARAMETERS_GENERIC || table_id == MMVQ_PARAMETERS_GCN) {
   376	        switch (ncols_dst) {
   377	            case 1:
   378	                return small_k ? nwarps : 1;
   379	            case 2:
   380	            case 3:
   381	            case 4:
   382	            case 5:
   383	            case 6:
   384	            case 7:
   385	            case 8:
   386	                return 2;
   387	            default:
   388	                return 1;
   389	        }
   390	    }
   391	    return 1;
   392	}
