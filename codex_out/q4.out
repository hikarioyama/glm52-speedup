   156	            break;
   157	        case 32:
   158	            launch_mm_ids_helper<32>(ids, ids_src1, ids_dst, expert_bounds, n_experts, n_tokens, n_expert_used, nchannels_y, si1, sis1, stream);
   159	            break;
   160	        default:
