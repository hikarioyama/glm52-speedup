   271	    return MMVQ_MAX_BATCH_SIZE;
   272	}
   273	
   274	// Device constexpr: returns the max batch size for the current arch+type at compile time.
   275	template <ggml_type type>
   276	static constexpr __device__ int get_mmvq_mmid_max_batch_for_device() {
   277	#if defined(RDNA4)
   278	    return get_mmvq_mmid_max_batch_rdna4(type);
   279	#elif defined(RDNA3)
   280	    return get_mmvq_mmid_max_batch_rdna3(type);
   281	#elif defined(RDNA2) || defined(RDNA1)
   282	    return get_mmvq_mmid_max_batch_rdna1_rdna2(type);
   283	#elif defined(CDNA)
   284	    return get_mmvq_mmid_max_batch_cdna(type);
   285	#elif defined(GCN)
   286	    return get_mmvq_mmid_max_batch_gcn(type);
   287	#elif defined(__CUDA_ARCH__) && (__CUDA_ARCH__ == GGML_CUDA_CC_VOLTA || __CUDA_ARCH__ >= GGML_CUDA_CC_ADA_LOVELACE)
   288	    return MMVQ_MAX_BATCH_SIZE;
   289	#elif defined(__CUDA_ARCH__) && __CUDA_ARCH__ >= GGML_CUDA_CC_TURING
   290	    return get_mmvq_mmid_max_batch_turing_plus(type);
   291	#else
   292	    return get_mmvq_mmid_max_batch_pascal_older(type);
   293	#endif
   294	}
