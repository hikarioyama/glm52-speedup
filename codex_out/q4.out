   257	template <int vdr> static __device__ __forceinline__ float vec_dot_q8_1_q8_1_impl(
   258	    const int * v, const int * u, const half2 & dm8, const half2 & ds8) {
   259	
   260	    int sumi = 0;
   261	
   262	#pragma unroll
   263	    for (int i = 0; i < vdr; ++i) {
   264	        // SIMD dot product of quantized values
   265	        sumi = ggml_cuda_dp4a(v[i], u[i], sumi);
   266	    }
   267	
   268	#ifdef FAST_FP16_AVAILABLE
   269	    const float2 tmp = __half22float2(__hmul2(dm8, ds8));
   270	    const float d8d8 = tmp.x;
   271	    const float m8s8 = tmp.y;
   272	#else
   273	    const float2 dm8f = __half22float2(dm8);
   274	    const float2 ds8f = __half22float2(ds8);
   275	    const float d8d8 = dm8f.x * ds8f.x;
   276	    const float m8s8 = dm8f.y * ds8f.y;
   277	#endif // FAST_FP16_AVAILABLE
   278	
   279	    // scale second part of sum by QI8_1/ vdr to compensate for multiple threads adding it
   280	    return sumi*d8d8 + m8s8 / (QI8_1 / vdr);
   281	}
