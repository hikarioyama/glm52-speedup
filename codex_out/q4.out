    64	enum mmvq_parameter_table_id {
    65	    MMVQ_PARAMETERS_GENERIC = 0,
    66	    MMVQ_PARAMETERS_GCN,
    67	    MMVQ_PARAMETERS_RDNA2,
    68	    MMVQ_PARAMETERS_RDNA3_0,
    69	    MMVQ_PARAMETERS_RDNA4
    70	};
    71	
    72	static constexpr __device__ mmvq_parameter_table_id get_device_table_id() {
    73	#if defined(RDNA4)
    74	    return MMVQ_PARAMETERS_RDNA4;
    75	#elif defined(RDNA3_0)
    76	    return MMVQ_PARAMETERS_RDNA3_0;
    77	#elif defined(RDNA2) || defined(RDNA3_5)
    78	    return MMVQ_PARAMETERS_RDNA2;
    79	#elif defined(GCN) || defined(CDNA)
    80	    return MMVQ_PARAMETERS_GCN;
    81	#else
    82	    return MMVQ_PARAMETERS_GENERIC;
    83	#endif
    84	}
    85	
    86	static __host__ mmvq_parameter_table_id get_device_table_id(int cc) {
    87	    if (GGML_CUDA_CC_IS_RDNA4(cc)) {
    88	        return MMVQ_PARAMETERS_RDNA4;
    89	    }
    90	    if (GGML_CUDA_CC_IS_RDNA3_0(cc)) {
    91	        return MMVQ_PARAMETERS_RDNA3_0;
    92	    }
    93	    if (GGML_CUDA_CC_IS_RDNA2(cc) || GGML_CUDA_CC_IS_RDNA3_5(cc)) {
    94	        return MMVQ_PARAMETERS_RDNA2;
    95	    }
    96	    if (GGML_CUDA_CC_IS_GCN(cc) || GGML_CUDA_CC_IS_CDNA(cc)) {
    97	        return MMVQ_PARAMETERS_GCN;
    98	    }
    99	    return MMVQ_PARAMETERS_GENERIC;
   100	}
