   283	template <int vdr> static __device__ __forceinline__ float vec_dot_q8_0_16_q8_1_impl(
   284	    const int * v, const int * u, const float * d8_0, const float & d8_1) {
   285	
   286	    float sumf = 0.0f;
   287	
   288	#pragma unroll
   289	    for (int i0 = 0; i0 < vdr; i0 += QI8_0/2) {
   290	        int sumi = 0;
   291	
   292	#pragma unroll
   293	        for (int i = i0; i < i0 + QI8_0/2; ++i) {
   294	            // SIMD dot product of quantized values
   295	            sumi = ggml_cuda_dp4a(v[i], u[i], sumi);
   296	        }
   297	
   298	        sumf += d8_0[i0/(QI8_0/2)]*sumi;
   299	    }
   300	
   301	    return d8_1*sumf;
   302	}
