   239	
   240	// Host function: returns the max batch size for the current arch+type at runtime.
   241	int get_mmvq_mmid_max_batch(ggml_type type, int cc) {
   242	    // NVIDIA: Volta, Ada Lovelace, and Blackwell always use MMVQ for MUL_MAT_ID.
   243	    if (GGML_CUDA_CC_IS_NVIDIA(cc)) {
   244	        if (cc == GGML_CUDA_CC_VOLTA || cc >= GGML_CUDA_CC_ADA_LOVELACE) {
   245	            return MMVQ_MAX_BATCH_SIZE;
   246	        }
   247	        if (cc >= GGML_CUDA_CC_TURING) {
   248	            return get_mmvq_mmid_max_batch_turing_plus(type);
   249	        }
   250	        return get_mmvq_mmid_max_batch_pascal_older(type);
   251	    }
   252	
   253	    // AMD
   254	    if (GGML_CUDA_CC_IS_AMD(cc)) {
   255	        if (GGML_CUDA_CC_IS_RDNA4(cc)) {
   256	            return get_mmvq_mmid_max_batch_rdna4(type);
   257	        }
   258	        if (GGML_CUDA_CC_IS_RDNA3(cc)) {
   259	            return get_mmvq_mmid_max_batch_rdna3(type);
   260	        }

