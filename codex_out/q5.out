  1493	static void * ggml_cuda_host_malloc(size_t size) {
  1494	    if (getenv("GGML_CUDA_NO_PINNED") != nullptr) {
  1495	        return nullptr;
  1496	    }
  1497	
  1498	    void * ptr = nullptr;
  1499	    cudaError_t err = cudaMallocHost((void **) &ptr, size);
  1500	    if (err != cudaSuccess) {
  1501	        // clear the error
  1502	        (void)cudaGetLastError();
  1503	        GGML_LOG_DEBUG("%s: failed to allocate %.2f MiB of pinned memory: %s\n", __func__,
  1504	                           size / 1024.0 / 1024.0, cudaGetErrorString(err));
  1505	        return nullptr;
  1506	    }
  1507	
  1508	    return ptr;
  1509	}
