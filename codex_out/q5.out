  1511	static ggml_backend_buffer_t ggml_backend_cuda_host_buffer_type_alloc_buffer(ggml_backend_buffer_type_t buft, size_t size) {
  1512	    void * ptr = ggml_cuda_host_malloc(size);
  1513	
  1514	    if (ptr == nullptr) {
  1515	        // fallback to cpu buffer
  1516	        return ggml_backend_buft_alloc_buffer(ggml_backend_cpu_buffer_type(), size);
  1517	    }
  1518	
  1519	    ggml_backend_buffer_t buffer = ggml_backend_cpu_buffer_from_ptr(ptr, size);
  1520	    buffer->buft = buft;
  1521	    buffer->iface.free_buffer = ggml_backend_cuda_host_buffer_free_buffer;
  1522	
  1523	    return buffer;
  1524	}
