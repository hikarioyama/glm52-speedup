   433	            return get_tensor_config_impl(GGML_BACKEND_SPLIT_AXIS_1);
   434	        }
   435	        if (std::regex_match(tensor_name, pattern_ssm_dt) || std::regex_match(tensor_name, pattern_ssm_a)) {
   436	            return get_tensor_config_impl(GGML_BACKEND_SPLIT_AXIS_0, "ssm_out.weight");
   437	        }
   438	        if (std::regex_match(tensor_name, pattern_ssm_alpha) || std::regex_match(tensor_name, pattern_ssm_beta) ||
   439	                std::regex_match(tensor_name, pattern_ssm_beta_alpha)) {
   440	            return get_tensor_config_impl(GGML_BACKEND_SPLIT_AXIS_1, "ssm_out.weight");
   441	        }
   442	        if (std::regex_match(tensor_name, pattern_r_cache) || std::regex_match(tensor_name, pattern_s_cache)) {
   443	            return get_tensor_config_impl(GGML_BACKEND_SPLIT_AXIS_0, "ssm_out.weight");
   444	        }
   445	        if (std::regex_match(tensor_name, pattern_ssm_conv1d)) {
   446	            return get_tensor_config_impl(GGML_BACKEND_SPLIT_AXIS_1, "ssm_out.weight");
   447	        }
   448	        if (std::regex_match(tensor_name, pattern_ssm_out_weight)) {
   449	            return get_tensor_config_impl(GGML_BACKEND_SPLIT_AXIS_0);
   450	        }
   451	
   452	        // FFN
   453	        if (std::regex_match(tensor_name, pattern_ffn_up_gate_weight)) {
   454	            return get_tensor_config_impl(GGML_BACKEND_SPLIT_AXIS_1, "ffn_down.weight", "ffn_down_exps.weight");
   455	        }
   456	        if (std::regex_match(tensor_name, pattern_ffn_up_gate_bias)) {
   457	            return get_tensor_config_impl(GGML_BACKEND_SPLIT_AXIS_0, "ffn_down.weight", "ffn_down_exps.weight");
   458	        }
   459	        if (std::regex_match(tensor_name, pattern_ffn_gate_up_weight)) {
   460	            return get_tensor_config_impl(GGML_BACKEND_SPLIT_AXIS_1, "ffn_down.weight", "ffn_down_exps.weight");
   461	        }
   462	        if (std::regex_match(tensor_name, pattern_ffn_down_weight)) {
   463	            return get_tensor_config_impl(GGML_BACKEND_SPLIT_AXIS_0, "ffn_down.weight", "ffn_down_exps.weight");
   464	        }
   465	        if (std::regex_match(tensor_name, pattern_ffn_down_bias)) {
   466	            return get_tensor_config_impl(GGML_BACKEND_SPLIT_AXIS_MIRRORED);
   467	        }
   468	        if (std::regex_match(tensor_name, pattern_ffn_down_exps_bias)) {
   469	            return get_tensor_config_impl(GGML_BACKEND_SPLIT_AXIS_PARTIAL);
   470	        }
   471	
   472	        // output
   473	        if (std::regex_match(tensor_name, pattern_output_weight)) {
   474	            return get_tensor_config_impl(GGML_BACKEND_SPLIT_AXIS_1);
   475	        }

