  1051	            // one ggml context per buffer type
  1052	            int max_n_tensors = n_tensors;
  1053	            max_n_tensors += 1;                 // duplicated output tensor
  1054	            max_n_tensors += hparams.n_layer*2; // duplicated rope freq tensors
  1055	            if (files.empty()) {
