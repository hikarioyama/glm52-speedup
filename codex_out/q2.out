  3277	// ggml_mul_mat_id
  3278	
  3279	/*
  3280	    c = ggml_mul_mat_id(ctx, as, b, ids);
  3281	
  3282	    as  -> [cols, rows, n_expert]
  3283	    b   -> [cols, n_expert_used, n_tokens]
  3284	    ids -> [n_expert_used, n_tokens] (i32)
  3285	    c   -> [rows, n_expert_used, n_tokens]
  3286	
  3287	    in b, n_expert_used can be broadcasted to match the n_expert_used of ids
  3288	
  3289	    c ~= as[:,:,i] @ b[:,i%r,t], i = ids[e,t] for all e,t in ids
  3290	*/
  3291	struct ggml_tensor * ggml_mul_mat_id(
  3292	        struct ggml_context * ctx,
  3293	        struct ggml_tensor  * as,
  3294	        struct ggml_tensor  * b,
  3295	        struct ggml_tensor  * ids) {
  3296	    GGML_ASSERT(!ggml_is_transposed(as));
  3297	    GGML_ASSERT(ids->type == GGML_TYPE_I32);
  3298	
  3299	    GGML_ASSERT(as->ne[3] == 1); // as is 3d (one matrix per expert)
  3300	    GGML_ASSERT(b->ne[3] == 1); // b is 3d
  3301	    GGML_ASSERT(ids->ne[2] == 1 && ids->ne[3] == 1); // ids is 2d
  3302	    GGML_ASSERT(ids->ne[1] == b->ne[2]); // must have an expert list per b row
  3303	    GGML_ASSERT(as->ne[0] == b->ne[0]); // can_mul_mat
  3304	    GGML_ASSERT(ids->ne[0] % b->ne[1] == 0); // can broadcast
  3305	
  3306	    const int64_t ne[4] = { as->ne[1], ids->ne[0], b->ne[2], 1 };
  3307	    struct ggml_tensor * result = ggml_new_tensor(ctx, GGML_TYPE_F32, 4, ne);
  3308	
  3309	    result->op     = GGML_OP_MUL_MAT_ID;
  3310	    result->src[0] = as;
  3311	    result->src[1] = b;
  3312	    result->src[2] = ids;
  3313	
  3314	    return result;
  3315	}
  3316	
  3317	// ggml_out_prod
  3318	
  3319	static inline bool ggml_can_out_prod(const struct ggml_tensor * t0, const struct ggml_tensor * t1) {
  3320	    static_assert(GGML_MAX_DIMS == 4, "GGML_MAX_DIMS is not 4 - update this function");
  3321	
  3322	    return (t0->ne[1] == t1->ne[1])   &&
  3323	           (t1->ne[2]%t0->ne[2] == 0) && // verify t0 is broadcastable
  3324	           (t1->ne[3]%t0->ne[3] == 0);
  3325	}
  3326	
  3327	struct ggml_tensor * ggml_out_prod(
  3328	        struct ggml_context * ctx,
  3329	        struct ggml_tensor  * a,
  3330	        struct ggml_tensor  * b) {
  3331	    GGML_ASSERT(ggml_can_out_prod(a, b));
  3332	    GGML_ASSERT(!ggml_is_transposed(a));
  3333	
  3334	    // a is broadcastable to b for ne[2] and ne[3] -> use b->ne[2] and b->ne[3]
  3335	    const int64_t ne[4] = { a->ne[0], b->ne[0], b->ne[2], b->ne[3] };
  3336	    struct ggml_tensor * result = ggml_new_tensor(ctx, GGML_TYPE_F32, 4, ne);
  3337	
  3338	    result->op     = GGML_OP_OUT_PROD;
  3339	    result->src[0] = a;
  3340	    result->src[1] = b;
  3341	
  3342	    return result;
  3343	}
