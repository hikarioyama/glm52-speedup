  1057	            }
  1058	            const size_t ctx_size = ggml_tensor_overhead()*max_n_tensors;
  1059	
  1060	            ggml_init_params params = {
  1061	                /*.mem_size   =*/ ctx_size,
  1062	                /*.mem_buffer =*/ NULL,
  1063	                /*.no_alloc   =*/ true,
  1064	            };
  1065	
