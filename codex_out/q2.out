  1047	        const buft_list_t * buft_list_layer, const LLM_TN_IMPL & tn, const std::initializer_list<int64_t> & ne, int flags) {
  1048	    auto ctx_for_buft = [&](ggml_backend_buffer_type_t buft) -> ggml_context * {
  1049	        auto it = ctx_map.find(buft);
