  1067	            if (!ctx) {
  1068	                throw std::runtime_error(format("failed to create ggml context"));
  1069	            }
  1070	
  1071	            ctx_map.emplace(buft, ctx);
  1072	
  1073	            return ctx;
  1074	        }
  1075	        return it->second.get();
