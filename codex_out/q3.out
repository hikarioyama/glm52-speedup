  4629	                continue;
  4630	            }
  4631	
  4632	            bool is_part_of_event = false;
  4633	            for (const auto & [start, end] : concurrent_node_ranges) {
  4634	                if (root_node_idx >= start && root_node_idx <= end) {
  4635	                    is_part_of_event = true;
  4636	                }
  4637	            }
  4638	
  4639	            if (is_part_of_event) {
  4640	                continue;
  4641	            }
  4642	
  4643	            std::vector<std::vector<const ggml_tensor *>> nodes_per_branch;
  4644	            for (int i = root_node_idx + 1; i < cgraph->n_nodes; ++i) {
  4645	                const ggml_tensor * node = cgraph->nodes[i];
  4646	                if (!is_noop(node) && depends_on(node, root_node)) {
  4647	                    nodes_per_branch.push_back({ node });
  4648	                }
  4649	            }
  4650	
  4651	            GGML_ASSERT(nodes_per_branch.size() == (size_t) count);
  4652	
  4653	            //find the join point
  4654	            const ggml_tensor * join_node = nullptr;
  4655	
  4656	            const auto & belongs_to_branch = [&](const ggml_tensor *                      node,
  4657	                                                 const std::vector<const ggml_tensor *> & branch) -> bool {
  4658	                for (const ggml_tensor * n : branch) {
  4659	                    if (depends_on(node, n)) {
  4660	                        return true;
  4661	                    }
  4662	                }
  4663	                return false;
  4664	            };
