  1371	    cublasHandle_t cublas_handles[GGML_CUDA_MAX_DEVICES] = {nullptr};
  1372	
  1373	    int curr_stream_no = 0;
  1374	
  1375	#ifdef USE_CUDA_GRAPH
  1376	    // Map from first_node_ptr to cuda_graph - allows multiple graphs per context
  1377	    // when the computation is split across CPU/GPU (e.g., with --n-cpu-moe)
  1378	    std::unordered_map<const void *, std::unique_ptr<ggml_cuda_graph>> cuda_graphs;
  1379	
  1380	    int64_t last_graph_eviction_sweep = 0;
  1381	
  1382	    ggml_cuda_graph * cuda_graph(const void * first_node_ptr) {
  1383	        const int64_t time_now = ggml_time_us();
  1384	
  1385	        // sweep every 5s, evicting cuda graphs unused for >=10s
  1386	        if (time_now - last_graph_eviction_sweep >= 5'000'000) {
  1387	            last_graph_eviction_sweep = time_now;
  1388	            for (auto it = cuda_graphs.begin(); it != cuda_graphs.end(); ) {
  1389	                if (time_now - it->second->last_used_time >= 10'000'000) {
  1390	                    it = cuda_graphs.erase(it);
  1391	                } else {
  1392	                    ++it;
  1393	                }
  1394	            }
  1395	        }
  1396	
  1397	        auto it = cuda_graphs.find(first_node_ptr);
  1398	        if (it == cuda_graphs.end()) {
  1399	            it = cuda_graphs.emplace(first_node_ptr, std::make_unique<ggml_cuda_graph>()).first;
  1400	        }
  1401	        it->second->last_used_time = time_now;
  1402	        return it->second.get();
  1403	    }
  1404	
  1405	    // Check if any CUDA graph is enabled for this context (used by kernels that need to know
  1406	    // if graphs are in use without having access to the specific graph key)
  1407	    bool any_cuda_graph_enabled() const {
  1408	        for (const auto & [key, graph] : cuda_graphs) {
  1409	            if (graph && graph->is_enabled()) {
  1410	                return true;
  1411	            }
  1412	        }
  1413	        return false;
  1414	    }
  1415	
  1416	    // Check if any CUDA graph has an instance for this context
  1417	    bool any_cuda_graph_has_instance() const {
  1418	        for (const auto & [key, graph] : cuda_graphs) {
  1419	            if (graph && graph->instance != nullptr) {
  1420	                return true;
  1421	            }
  1422	        }
  1423	        return false;
  1424	    }

