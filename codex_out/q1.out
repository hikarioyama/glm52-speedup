  1547	/// kernels
  1548	
  1549	typedef void (*ggml_cuda_op_mul_mat_t)(
  1550	    ggml_backend_cuda_context & ctx,
  1551	    const ggml_tensor * src0, const ggml_tensor * src1, ggml_tensor * dst, const char * src0_dd_i, const float * src1_ddf_i,
  1552	    const char * src1_ddq_i, float * dst_dd_i, const int64_t row_low, const int64_t row_high, const int64_t src1_ncols,
  1553	    const int64_t src1_padded_row_size, cudaStream_t stream);
  1554	
  1555	#ifndef GGML_CUDA_PEER_MAX_BATCH_SIZE
  1556	#define GGML_CUDA_PEER_MAX_BATCH_SIZE 128
  1557	#endif // GGML_CUDA_PEER_MAX_BATCH_SIZE
  1558	
  1559	#define MUL_MAT_SRC1_COL_STRIDE 128
  1560	
  1561	static cudaError_t ggml_cuda_cpy_tensor_2d(
  1562	    void * dst, const struct ggml_tensor * src, int64_t i3, int64_t i2, int64_t i1_low, int64_t i1_high, cudaStream_t stream) {
  1563	
  1564	    const char * src_ptr = (const char *) src->data;
  1565	    char       * dst_ptr = (char       *) dst;
  1566	
  1567	    const int64_t ne0 = src->ne[0];
  1568	    const int64_t nb0 = src->nb[0];
  1569	    const int64_t nb1 = src->nb[1];
  1570	    const int64_t nb2 = src->nb[2];
  1571	    const int64_t nb3 = src->nb[3];
  1572	    const enum ggml_type type = src->type;
  1573	    const int64_t ts = ggml_type_size(type);
  1574	    const int64_t bs = ggml_blck_size(type);
  1575	    const int64_t i1_diff = i1_high - i1_low;
  1576	
  1577	    const char * x = src_ptr + i1_low*nb1 + i2*nb2 + i3*nb3;
  1578	    if (nb0 == ts && nb1 == ts*ne0/bs) {
  1579	        return cudaMemcpyAsync(dst_ptr, x, i1_diff*nb1, cudaMemcpyDeviceToDevice, stream);
  1580	    } else if (nb0 == ts) {
  1581	        return cudaMemcpy2DAsync(dst_ptr, ts*ne0/bs, x, nb1, ts*ne0/bs, i1_diff, cudaMemcpyDeviceToDevice, stream);
  1582	    } else {
  1583	        for (int64_t i1 = 0; i1 < i1_diff; i1++) {
  1584	            const void * rx = (const void *) ((const char *) x + i1*nb1);
  1585	            void * rd = (void *) (dst_ptr + i1*ts*ne0/bs);
  1586	            // pretend the row is a matrix with cols=1
  1587	            cudaError_t r = cudaMemcpy2DAsync(rd, ts/bs, rx, nb0, ts/bs, ne0, cudaMemcpyDeviceToDevice, stream);
  1588	            if (r != cudaSuccess) {
  1589	                return r;
  1590	            }
  1591	        }
  1592	        return cudaSuccess;
  1593	    }
  1594	}
  1595	

